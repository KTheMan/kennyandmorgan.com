# Server Configuration
PORT=3000
NODE_ENV=development
GUEST_DB_PATH=./data/guests.db
ADMIN_PASSWORD=Binx123!

# Registry IDs (Replace with your actual registry IDs)
AMAZON_REGISTRY_ID=your-amazon-registry-id
TARGET_REGISTRY_ID=your-target-registry-id
CRATE_AND_BARREL_REGISTRY_ID=your-crate-and-barrel-registry-id
POTTERY_BARN_REGISTRY_ID=your-pottery-barn-registry-id
WILLIAMS_SONOMA_REGISTRY_ID=your-williams-sonoma-registry-id
REI_REGISTRY_ID=your-rei-registry-id
ZOLA_REGISTRY_ID=your-zola-registry-id
HEATH_CERAMICS_REGISTRY_ID=your-heath-ceramics-registry-id

# API Keys (if needed for official APIs)
AMAZON_API_KEY=your-amazon-api-key
AMAZON_API_SECRET=your-amazon-api-secret
AMAZON_ASSOCIATE_TAG=your-amazon-associate-tag

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,https://ktheman.github.io

# Registry Cache
REGISTRY_POLL_INTERVAL_MS=3600000
REGISTRY_FAST_POLL_INTERVAL_MS=120000
REGISTRY_FAST_POLL_DURATION_MS=1800000
REGISTRY_FAST_POLL_SWEEP_MS=30000
REGISTRY_FAST_POLL_BATCH_LIMIT=5
